# Public browser configuration. Never put Gemini or Supabase secret keys here.
VITE_API_BASE_URL=http://127.0.0.1:54321/functions/v1

# Server-only names used with `supabase functions serve --env-file`.
# Fill these in a local ignored env file or Supabase Secrets.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Use either gemini-2.5-flash or gemini-3.1-flash-lite.
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FILE_SEARCH_STORE=
GEMINI_API_KEY=
PASSCODE_HASH=
SESSION_SIGNING_SECRET=
