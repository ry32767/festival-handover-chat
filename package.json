{
  "name": "festival-handover-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "security:scan": "tsx scripts/secret-scan.ts",
    "auth:setup": "tsx scripts/setup-local-auth.ts",
    "knowledge:import-llm": "tsx scripts/import-llm-knowledge.ts",
    "knowledge:verify": "tsx scripts/verify-gemini-file-search.ts",
    "knowledge:validate": "tsx scripts/validate-knowledge.ts",
    "knowledge:anonymization-check": "tsx scripts/anonymization-check.ts",
    "knowledge:build-index": "tsx scripts/build-knowledge-index.ts",
    "knowledge:sync": "tsx scripts/sync-file-search.ts",
    "functions:test": "deno test --allow-env supabase/functions",
    "supabase:functions:serve": "supabase functions serve --no-verify-jwt --env-file supabase/functions/.env.local"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "deno": "2.9.2",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "supabase": "2.109.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
